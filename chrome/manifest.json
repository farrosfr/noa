{
  "manifest_version": 3,
  "name": "Content Guardrail",
  "version": "1.0",
  "description": "Enforces corporate content policies.",
  "permissions": ["scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}